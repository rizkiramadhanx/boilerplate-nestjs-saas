DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

NODE_ENV=development
TZ=UTC

FRONT_END_URL=http://localhost:5173

# Comma-separated list of additional allowed CORS origins (production domains).
# Example: https://app.kamu.com,https://admin.kamu.com
ALLOW_ORIGINS=

PORT=4000

# Secret untuk registrasi admin
ADMIN_SECRET_REGISTER=

# Bahasa default (id / en)
LANGUAGE=id

JWT_SECRET=
JWT_EXPIRES_IN=3600s
JWT_ADMIN_EXPIRES_IN=30d

JWT_SECRET_REFRESH=
JWT_EXPIRES_IN_REFRESH=30d

MAIL_HOST=smtp.sumopod.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_FROM_NAME=

APP_URL=

# Pakasir payment gateway
# Setelah bayar: tombol kembali ke merchant (query redirect).
# Jika kosong, dipakai FRONT_END_URL/billing/callback lalu APP_URL/billing/callback.
PAKASIR_REDIRECT_URL=http://localhost:5173
PAKASIR_PROJECT_SLUG=
PAKASIR_API_KEY=
PAKASIR_SANDBOX=false
# Opsional: override host API Pakasir (default app.pakasir.com / sandbox.pakasir.com dari PAKASIR_SANDBOX)
# PAKASIR_API_ORIGIN=https://app.pakasir.com

# WhatsApp (go-whatsapp-web-multidevice)
# https://github.com/aldinokemal/go-whatsapp-web-multidevice
WA_BASE_URL=http://localhost:3001
WA_BASIC_AUTH_USER=
WA_BASIC_AUTH_PASS=
WA_GRUP_SUPPORT=https://chat.whatsapp.com/xxxxxxxxxxxxxxxxxxxxxxxx
