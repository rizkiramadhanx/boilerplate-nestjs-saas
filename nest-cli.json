{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "modules/app/mailer/templates/**/*.hbs", "outDir": "dist" },
      { "include": "i18n/**/*.json", "outDir": "dist" }
    ],
    "watchAssets": true
  },
  "generateOptions": {
    "spec": true
  }
}
