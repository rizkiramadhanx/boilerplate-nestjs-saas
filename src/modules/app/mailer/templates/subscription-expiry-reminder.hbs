<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN" "http://www.w3.org/TR/html4/loose.dtd">
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <title>Langganan Hampir Berakhir - {{appName}}</title>
  <style type="text/css">
    body, html { margin: 0; padding: 0; background-color: #f4f6fa; font-family: Arial, sans-serif; }
    table { border-collapse: collapse; }
    td { font-family: Arial, sans-serif; }
    .wrapper { width: 100%; table-layout: fixed; background-color: #f4f6fa; padding-bottom: 40px; }
    .main { background-color: #ffffff; margin: 0 auto; width: 100%; max-width: 600px; border-spacing: 0; color: #1f2937; }
    .header { background-color: #00529B; padding: 28px 20px; color: #ffffff; }
    .brand { font-size: 24px; font-weight: bold; letter-spacing: 0.5px; color: #ffffff; margin: 0; }
    .tagline { font-size: 13px; color: #e6eefc; margin-top: 4px; }
    .content { padding: 32px 30px; line-height: 1.6; color: #1f2937; }
    .warning-badge { background-color: #fef9c3; border: 1px solid #fde047; border-radius: 6px; padding: 16px; text-align: center; margin: 20px 0; }
    .warning-badge p { margin: 0; font-size: 16px; font-weight: bold; color: #854d0e; }
    .detail-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
    .detail-table td { padding: 10px 12px; font-size: 14px; border-bottom: 1px solid #f1f5f9; }
    .detail-table td:first-child { color: #6b7280; width: 45%; }
    .detail-table td:last-child { font-weight: 600; color: #1f2937; }
    .button { background-color: #00529B; color: #ffffff !important; padding: 12px 26px; text-decoration: none; border-radius: 6px; font-weight: bold; display: inline-block; }
    .footer { background-color: #f4f6fa; color: #6b7280; text-align: center; padding: 20px; font-size: 12px; }
  </style>
</head>
<body>
  <center class="wrapper">
    <table class="main" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td class="header" align="center">
          <p class="brand">{{appName}}</p>
          <p class="tagline">Catat transaksi, hitung untung, kelola pembukuan agen kamu</p>
        </td>
      </tr>
      <tr>
        <td class="content">
          <p>Halo {{ownerName}},</p>
          <p>Langganan <strong>{{appName}}</strong> kamu akan berakhir dalam <strong>{{daysLeft}} hari</strong>.</p>
          <div class="warning-badge">
            <p>⚠ Berakhir pada {{periodEnd}}</p>
          </div>
          <table class="detail-table">
            <tr><td>Paket aktif</td><td>{{plan}}</td></tr>
            <tr><td>Berakhir pada</td><td>{{periodEnd}}</td></tr>
          </table>
          <p>Perpanjang sekarang supaya akun kamu tidak terganggu dan data tetap aman.</p>
          <p style="text-align: center; margin: 28px 0;">
            <a href="{{renewLink}}" class="button">Perpanjang Sekarang</a>
          </p>
          <p style="font-size: 13px; color: #6b7280;">Jika kamu sudah memperpanjang, abaikan email ini.</p>
        </td>
      </tr>
      <tr>
        <td class="footer">
          <p>&copy; 2026 {{appName}}. All rights reserved.</p>
        </td>
      </tr>
    </table>
  </center>
</body>
</html>
